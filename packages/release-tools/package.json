{
  "name": "release-tools",
  "version": "1.0.0",
  "description": "Scripts used for release management of the widgets tools packages.",
  "private": true,
  "main": "./createRelease.ts",
  "scripts": {
    "release:pwt": "ts-node --project ./tsconfig.json ./createRelease.ts pwt",
    "release:gw": "ts-node --project ./tsconfig.json ./createRelease.ts gw",
    "build:release:parser": "peggy -o ./utils/changelog-parser/changelog.js ./utils/changelog-parser/changelog.pegjs"
  },
  "devDependencies": {
    "@types/node": "^16.11.19",
    "@types/node-fetch": "2.6.13",
    "peggy": "^1.2.0",
    "typescript": "^4.8.4"
  },
  "dependencies": {
    "node-fetch": "^2.7.0",
    "ts-node": "^10.9.1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC"
}
